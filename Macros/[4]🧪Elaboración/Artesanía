function cfg(msg: string): void { client.sysMsg(`[FABRICAR HERRAMIENTAS] ${msg}`, 0x44); }
function err(msg: string): void { client.sysMsg(`[FABRICAR HERRAMIENTAS] ${msg}`, 0x26); }

// Siempre buscamos sin filtro de hue y filtramos por .hue manualmente,
// porque findAllItemsOfType trata hue=0 igual que null (sin filtro).

function contarUnidades(serial: number, graphic: number, hue: number): number {
  const items = client.findAllItemsOfType(graphic, null, { serial }, null, 0);
  let total = 0;
  for (const it of items) { if (it.hue === hue) total += it.amount; }
  return total;
}

function contarUnidadesSinHue(serial: number, graphic: number): number {
  const items = client.findAllItemsOfType(graphic, null, { serial }, null, 0);
  let total = 0;
  for (const it of items) total += it.amount;
  return total;
}

function moverUnidades(origen: number, destino: number, graphic: number, cantidad: number, hue: number): number {
  let movidas = 0;
  while (movidas < cantidad) {
    const todos = client.findAllItemsOfType(graphic, null, { serial: origen }, null, 0);
    const item = todos.find(it => it.hue === hue);
    if (!item) break;
    const aMover = Math.min(item.amount, cantidad - movidas);
    player.moveItem(item, { serial: destino }, 0, 0, 0, aMover);
    sleep(CFG.SLEEP_MOVE);
    movidas += aMover;
  }
  return movidas;
}

function moverUnidadesSinHue(origen: number, destino: number, graphic: number, cantidad: number): number {
  let movidas = 0;
  while (movidas < cantidad) {
    const todos = client.findAllItemsOfType(graphic, null, { serial: origen }, null, 0);
    const item = todos[0];
    if (!item) break;
    const aMover = Math.min(item.amount, cantidad - movidas);
    player.moveItem(item, { serial: destino }, 0, 0, 0, aMover);
    sleep(CFG.SLEEP_MOVE);
    movidas += aMover;
  }
  return movidas;
}

function pesoLibre(): number {
  return Math.max(0, player.weightMax - CFG.MARGEN_PESO_LIBRE - player.weight);
}


