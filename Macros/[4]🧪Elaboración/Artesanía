const WS_AVISO  = "Dentro de 1 minuto habra un SAVE automatico";
const WS_INICIO = "Comienza la grabacion del mundo";
const WS_FIN    = "Comienza la grabacion de las bases de datos";

function checkWorldSave(): void {
  if (journal.containsText(WS_AVISO)) {
    client.sysMsg("[FABRICAR HERRAMIENTAS] Save en 1 min. Pausando...", 0x26);
    journal.clear();
    journal.waitForText(WS_INICIO, undefined, 90000);
    journal.clear();
    journal.waitForText(WS_FIN, undefined, 180000);
    client.sysMsg("[FABRICAR HERRAMIENTAS] Save terminado. Continuando.", 0x44);
    journal.clear();
    sleep(3000);
    return;
  }
  if (journal.containsText(WS_INICIO)) {
    client.sysMsg("[FABRICAR HERRAMIENTAS] Save en curso. Esperando...", 0x26);
    journal.clear();
    journal.waitForText(WS_FIN, undefined, 180000);
    client.sysMsg("[FABRICAR HERRAMIENTAS] Save terminado. Continuando.", 0x44);
    journal.clear();
    sleep(3000);
  }
}


