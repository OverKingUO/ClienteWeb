// ============================================================
// BLOQUE 5 — SELECCIÓN DE BOLSAS CON VALIDACIÓN MULTI-RECURSO
// ============================================================
//
// La macro pide bolsas al jugador hasta que todos los recursos queden cubiertos.
// Reglas:
//   · Si una bolsa tiene TODOS los recursos pendientes  → cubre todo de una vez.
//   · Si tiene ALGUNOS                                  → acepta esos, pide otra para el resto.
//   · Si no tiene NINGUNO de los pendientes             → rechaza y repite la pregunta.
//   · Una misma bolsa puede cubrir varios recursos simultáneamente.

function pedirDestinoAbierto(paso: string): number {
  cfg(`${paso} — Haz clic en el CONTENEDOR DESTINO...`);
  const t = target.query(false);
  if (!t || !t.serial) { err("Selección cancelada. Macro detenida."); exit(); }
  player.use(t.serial);
  sleep(800);
  return t.serial;
}

// serialPorRecurso[i] = serial de la bolsa asignada al recurso i de def.recursos
const serialPorRecurso: number[] = new Array(def.recursos.length).fill(0);
const totalPasos = def.recursos.length + 2; // herramientas + materiales(1..N) + destino

// ── Paso 1: bolsa de herramientas de fabricación ─────────────
cfg(`1/${totalPasos} — Haz clic en la bolsa con HERRAMIENTAS DE TINKER...`);
let serialBolsaHerramientas = 0;
while (true) {
  const t = target.query(false);
  if (!t || !t.serial) { err("Selección cancelada. Macro detenida."); exit(); }
  player.use(t.serial);
  sleep(800);
  const cantidad = contarUnidades(t.serial, def.herramientaFabricacionGraphic, def.herramientaFabricacionHue);
  if (cantidad > 0) {
    serialBolsaHerramientas = t.serial;
    cfg(`Bolsa de herramientas OK (${cantidad} unidades).`);
    break;
  }
  err("Esa bolsa no tiene herramientas de tinker del tipo correcto. Selecciona otra...");
}

// ── Pasos 2..N: bolsas de materiales ─────────────────────────
let pendientes: number[] = def.recursos.map((_, i) => i);
let numeroPaso = 2;

while (pendientes.length > 0) {
  const nombresPendientes = pendientes.map(i => def.recursos[i].nombre).join(", ");
  cfg(`${numeroPaso}/${totalPasos} — Bolsa con: ${nombresPendientes}...`);

  const t = target.query(false);
  if (!t || !t.serial) { err("Selección cancelada. Macro detenida."); exit(); }
  player.use(t.serial);
  sleep(800);

  const cubiertosAhora: number[] = [];
  for (const i of pendientes) {
    const r = def.recursos[i];
    if (contarUnidades(t.serial, r.graphic, r.hue) > 0) {
      serialPorRecurso[i] = t.serial;
      cubiertosAhora.push(i);
      cfg(`  OK: ${r.nombre} encontrado.`);
    }
  }

  if (cubiertosAhora.length === 0) {
    err(`Esa bolsa no contiene ninguno de los materiales pendientes (${nombresPendientes}). Selecciona otra...`);
    continue;
  }

  pendientes = pendientes.filter(i => !cubiertosAhora.includes(i));
  numeroPaso++;
  if (pendientes.length > 0) {
    cfg(`Faltan por asignar: ${pendientes.map(i => def.recursos[i].nombre).join(", ")}.`);
  }
}

cfg("Todas las bolsas de materiales seleccionadas.");

// ── Último paso: contenedor destino ──────────────────────────
const serialDestino = pedirDestinoAbierto(`${numeroPaso}/${totalPasos}`);


// ============================================================
// BLOQUE 6 — CÁLCULO DE CARGA Y CARGA INICIAL
// ============================================================

// a) Vaciar resultados previos en mochila
let resultadosEnMochila = contarUnidadesSinHue(player.backpack!.serial, def.resultGraphic);
if (resultadosEnMochila > 0) {
  cfg(`Enviando ${resultadosEnMochila} resultado(s) previos al destino...`);
  moverUnidadesSinHue(player.backpack!.serial, serialDestino, def.resultGraphic, resultadosEnMochila);
  sleep(CFG.SLEEP_MOVE);
}

// b) Cargar herramientas de fabricación si faltan
const herramientasYaEnMochila = contarUnidades(player.backpack!.serial, def.herramientaFabricacionGraphic, def.herramientaFabricacionHue);
if (herramientasYaEnMochila < CFG.HERRAMIENTAS_EN_MOCHILA) {
  const faltan = CFG.HERRAMIENTAS_EN_MOCHILA - herramientasYaEnMochila;
  const dispHerr = contarUnidades(serialBolsaHerramientas, def.herramientaFabricacionGraphic, def.herramientaFabricacionHue);
  const cabenPorPeso = Math.floor(pesoLibre() / def.herramientaFabricacionPeso);
  const aMover = Math.min(faltan, dispHerr, cabenPorPeso);
  if (aMover > 0) {
    moverUnidades(serialBolsaHerramientas, player.backpack!.serial, def.herramientaFabricacionGraphic, aMover, def.herramientaFabricacionHue);
  }
}
if (contarUnidades(player.backpack!.serial, def.herramientaFabricacionGraphic, def.herramientaFabricacionHue) === 0) {
  err("No hay herramientas de fabricación disponibles. Macro detenida."); exit();
}

// c) Cargar materiales para cada recurso.
//
// Lógica de peso:
//   El peso disponible para materiales es el peso libre actual menos
//   el peso del resultado (se reserva para cuando esté fabricado y
//   aún no se haya movido al destino) y menos el peso de los recursos
//   de iteraciones anteriores ya cargados.
//
//   Se calcula cuántos crafts completos caben con el peso disponible
//   y se carga material para ese número de crafts.
//   Si solo cabe material para 1 craft, se carga para 1.
//   Solo para si NO hay suficiente material ni para 1 craft.

const nivelObjetivo: number[] = new Array(def.recursos.length).fill(0);

// Primero calcular cuántos crafts caben con el peso libre total,
// considerando TODOS los recursos a la vez (multi-recurso).
// pesoTotalPorCraft = suma del peso de cada recurso * su cantidad
const pesoTotalPorCraft = def.recursos.reduce((acc, r) => acc + r.peso * r.cantidad, 0);
const pesoDisponibleTotal = pesoLibre() - def.resultPeso;

if (pesoDisponibleTotal < pesoTotalPorCraft) {
  // No cabe ni un craft — calcular cuánto material ya hay en mochila
  // para ver si aun así podemos hacer alguno con lo que hay
  const craftsPosiblesPorMochila = def.recursos.reduce((min, r) => {
    const enMochila = contarUnidades(player.backpack!.serial, r.graphic, r.hue);
    return Math.min(min, Math.floor(enMochila / r.cantidad));
  }, Infinity);

  if (craftsPosiblesPorMochila < 1) {
    err(`Peso libre insuficiente para cargar material de un craft completo.`);
    err(`Necesitas ${pesoTotalPorCraft.toFixed(1)} libres, tienes ${pesoDisponibleTotal.toFixed(1)}.`);
    exit();
  }
  // Hay material en mochila para al menos 1 craft — continuar sin cargar más
  cfg(`Peso justo. Usando material ya en mochila (${craftsPosiblesPorMochila} craft/s posibles).`);
  for (let i = 0; i < def.recursos.length; i++) {
    nivelObjetivo[i] = contarUnidades(player.backpack!.serial, def.recursos[i].graphic, def.recursos[i].hue);
  }
} else {
  // Caben crafts — calcular cuántos y cargar material para ese número
  const craftsACubrir = Math.max(1, Math.floor(pesoDisponibleTotal / pesoTotalPorCraft));
  cfg(`Cargando material para ${craftsACubrir} craft/s...`);

  for (let i = 0; i < def.recursos.length; i++) {
    const r = def.recursos[i];
    const yaEnMochila = contarUnidades(player.backpack!.serial, r.graphic, r.hue);
    const objetivo = craftsACubrir * r.cantidad;
    const aCargar = Math.max(0, objetivo - yaEnMochila);

    if (aCargar > 0) {
      const dispEnBolsa = contarUnidades(serialPorRecurso[i], r.graphic, r.hue);
      const aMover = Math.min(aCargar, dispEnBolsa);
      if (aMover > 0) {
        moverUnidades(serialPorRecurso[i], player.backpack!.serial, r.graphic, aMover, r.hue);
      }
    }

    nivelObjetivo[i] = contarUnidades(player.backpack!.serial, r.graphic, r.hue);

    if (nivelObjetivo[i] < r.cantidad) {
      err(`${r.nombre} insuficiente (${nivelObjetivo[i]}/${r.cantidad}). Macro detenida.`);
      exit();
    }

    cfg(`${r.nombre}: ${nivelObjetivo[i]} unidades listas.`);
  }
}


// ============================================================
// BLOQUE 7 — NAVEGAR EL MENÚ UNA VEZ
// ============================================================

function abrirMenu(): any {
  const candidatos = client.findAllItemsOfType(def.herramientaFabricacionGraphic, null, player.backpack, null, 0);
  const h = candidatos.find(it => it.hue === def.herramientaFabricacionHue) ?? null;
  if (!h) { err("Sin herramienta de fabricación en mochila."); return null; }
  player.use(h);
  return Gump.findOrWait(CFG.GUMP_TINKERING, CFG.SLEEP_GUMP);
}

const gump1 = abrirMenu();
if (!gump1 || !gump1.exists) { err("No se abrió el menú de fabricación."); exit(); }

gump1.reply(def.categoriaId);
sleep(CFG.SLEEP_NAV);

if (def.paginaSiguiente) {
  const gumpPag = Gump.findOrWait(CFG.GUMP_TINKERING, 2000);
  if (!gumpPag || !gumpPag.exists) { err("No se pudo navegar a la página siguiente."); exit(); }
  gumpPag.reply(CFG.BTN_SIGUIENTE);
  sleep(CFG.SLEEP_NAV);
}

const gump2 = Gump.findOrWait(CFG.GUMP_TINKERING, 2000);
if (!gump2 || !gump2.exists) { err("El menú desapareció al seleccionar categoría."); exit(); }

gump2.reply(def.herramientaId);
sleep(CFG.SLEEP_NAV);


// ============================================================
// BLOQUE 8 — REPOSICIÓN MULTI-RECURSO
// ============================================================

function reponerHerramientasFabricacion(): boolean {
  const enMochila = contarUnidades(player.backpack!.serial, def.herramientaFabricacionGraphic, def.herramientaFabricacionHue);
  if (enMochila >= CFG.HERRAMIENTAS_EN_MOCHILA) return true;
  const faltan = CFG.HERRAMIENTAS_EN_MOCHILA - enMochila;
  const disponibles = contarUnidades(serialBolsaHerramientas, def.herramientaFabricacionGraphic, def.herramientaFabricacionHue);
  if (disponibles === 0) return enMochila > 0;
  const cabenPorPeso = Math.floor(pesoLibre() / def.herramientaFabricacionPeso);
  const aMover = Math.min(faltan, disponibles, cabenPorPeso);
  if (aMover > 0) {
    moverUnidades(serialBolsaHerramientas, player.backpack!.serial, def.herramientaFabricacionGraphic, aMover, def.herramientaFabricacionHue);
  }
  return contarUnidades(player.backpack!.serial, def.herramientaFabricacionGraphic, def.herramientaFabricacionHue) > 0;
}

function reponerRecurso(i: number): boolean {
  const r = def.recursos[i];
  const enMochila = contarUnidades(player.backpack!.serial, r.graphic, r.hue);
  if (enMochila >= nivelObjetivo[i]) return true;
  const disponible = contarUnidades(serialPorRecurso[i], r.graphic, r.hue);
  if (disponible === 0) return enMochila >= r.cantidad;
  const faltan = nivelObjetivo[i] - enMochila;
  const pesoDisponible = pesoLibre() - def.resultPeso;
  const cabenPorPeso = Math.max(0, Math.floor(pesoDisponible / r.peso));
  const aMover = Math.min(faltan, disponible, cabenPorPeso);
  if (aMover > 0) {
    moverUnidades(serialPorRecurso[i], player.backpack!.serial, r.graphic, aMover, r.hue);
  }
  return contarUnidades(player.backpack!.serial, r.graphic, r.hue) >= r.cantidad;
}

function reponerTodosLosMateriales(): boolean {
  for (let i = 0; i < def.recursos.length; i++) {
    if (!reponerRecurso(i)) return false;
  }
  return true;
}

function hayMaterialSuficienteParaCraft(): boolean {
  for (const r of def.recursos) {
    if (contarUnidades(player.backpack!.serial, r.graphic, r.hue) < r.cantidad) return false;
  }
  return true;
}


// ============================================================
// BLOQUE 9 — BUCLE DE FABRICACIÓN
// ============================================================

let fabricadas = 0;

while (true) {

  // Parar si SUBIR_HABILIDAD está activo y Tinkering llegó a 100.0
  if (SUBIR_HABILIDAD) {
    const tinker = player.getSkill(Skills.Tinkering);
    if (tinker && tinker.value >= 1000) {
      cfg("¡Tinkering al 100.0! Macro detenida.");
      break;
    }
  }

  const ocupado = contarUnidadesSinHue(serialDestino, def.resultGraphic);
  if (ocupado >= CFG.LIMITE_CONTENEDOR) break;

  if (!reponerHerramientasFabricacion()) break;
  if (!reponerTodosLosMateriales()) break;
  if (!hayMaterialSuficienteParaCraft()) break;

  checkWorldSave();

  const candidatosH = client.findAllItemsOfType(def.herramientaFabricacionGraphic, null, player.backpack, null, 0);
  const h = candidatosH.find(it => it.hue === def.herramientaFabricacionHue) ?? null;
  if (!h) { err("Herramienta desapareció de la mochila."); break; }

  player.use(h);
  const gump = Gump.findOrWait(CFG.GUMP_TINKERING, 3000);
  if (!gump || !gump.exists) {
    err("No se pudo reabrir el menú. Reintentando...");
    sleep(1000);
    continue;
  }

  // Snapshot de materiales antes de fabricar (para detectar consumo = fallo de craft)
  const snapshotAntes = def.recursos.map(r =>
    contarUnidades(player.backpack!.serial, r.graphic, r.hue)
  );

  journal.clear();
  gump.reply(CFG.BTN_FABRICAR_ULTIMO);

  const resp = journal.waitForTextAny(TODOS_MSGS_CRAFT, undefined, CFG.TIMEOUT_CRAFT);

  if (resp !== null && JOURNAL_FABRICACION.SIN_MATERIAL.some(m => resp.includes(m))) {
    break;
  }

  const todosResultados = client.findAllItemsOfType(def.resultGraphic, null, player.backpack, null, 0);
  const fabricado = todosResultados.length > 0 ? todosResultados[0] : null;

  if (fabricado) {
    fabricadas++;
    player.moveItem(fabricado, { serial: serialDestino }, 0, 0, 0, 1);
    sleep(CFG.SLEEP_MOVE);
    continue;
  }

  // Sin resultado: comprobar si se consumió material (fallo craft) o no (timeout)
  const seConsumioBien = def.recursos.some((r, i) =>
    contarUnidades(player.backpack!.serial, r.graphic, r.hue) < snapshotAntes[i]
  );

  if (seConsumioBien) {
    sleep(500);
    continue;
  }

  err("Sin respuesta del servidor. Reintentando...");
  sleep(1000);
}

cfg(`Finalizado. Herramientas fabricadas: ${fabricadas}.`);
