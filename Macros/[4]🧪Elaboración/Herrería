// Gráfico del lingote según el material.
// La mayoría de metales comparten el gráfico "estándar" 0x1BEF y se diferencian
// solo por el hue. Plata y Oro tienen gráfico propio (ver ua-crafting-items).
function graficoLingote(material: Material): { graphic: number; hue: number | null } {
  if (material.nombre === "Plata") return { graphic: 0x1BF5, hue: null };
  if (material.nombre === "Oro")   return { graphic: 0x1BE9, hue: null };
  return { graphic: 0x1BEF, hue: material.hue };
}


