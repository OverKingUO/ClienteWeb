// ============================================================
// BLOQUE 7 — SELECCIÓN DE BOLSAS
// ============================================================
//
// Mismo problema conocido que en Alquimia: abrir un contenedor padre cierra
// los contenedores hijos que ya estaban abiertos. Reutilizamos el mismo patrón
// de registro de bolsas abiertas para no reabrir innecesariamente.

const bolsasAbiertas: Set<number> = new Set();

// Pre-cargar en bolsasAbiertas todos los contenedores que el jugador
// ya tiene abiertos ANTES de que la macro empiece a pedir selecciones.
// Evita que al seleccionar el contenedor padre la macro lo reabra y cierre los hijos.
function precargarContenedoresAbiertos(): void {
  if (!player.backpack) return;
  const recorrer = (items: any[]) => {
    for (const it of items) {
      if (Array.isArray(it.contents) && it.contents.length > 0) {
        bolsasAbiertas.add(it.serial);
        recorrer(it.contents);
      }
    }
  };
  recorrer((player.backpack as any).contents ?? []);
}
precargarContenedoresAbiertos();

function estaAbierto(serial: number): boolean {
  return bolsasAbiertas.has(serial);
}

function abrirSiNecesario(serial: number): void {
  if (estaAbierto(serial)) return;
  player.use(serial);
  sleep(1200);
  bolsasAbiertas.add(serial);
}

function pedirBolsaConContenido(paso: string, graphic: number, hue: number | null, nombreItem: string): number {
  while (true) {
    cfg(`${paso} — Haz clic en la bolsa con ${nombreItem}...`);
    const t = target.query(false);
    if (!t || !t.serial) { err("Selección cancelada."); exit(); }

    abrirSiNecesario(t.serial);

    if (contarUnidades(t.serial, graphic, hue) > 0) return t.serial;

    err(`Ahí no hay ${nombreItem}. Selecciona la bolsa correcta...`);
  }
}

function pedirBolsaAbierta(paso: string, descripcion: string): number {
  cfg(`${paso} — Haz clic en ${descripcion}...`);
  const t = target.query(false);
  if (!t || !t.serial) { err("Selección cancelada."); exit(); }
  abrirSiNecesario(t.serial);
  return t.serial;
}

// Localiza el Sistema de Recompensas automáticamente por cercanía (sin target.query).
// sourceSerial=null hace que 'range' sea un radio espacial en casillas alrededor del jugador,
// no una profundidad de contenedor (ver Ultima Alianza — Buenas prácticas, sección 10).
const RANGO_SISTEMA_RECOMPENSAS = 2;

function localizarSistemaRecompensas(): number {
  const obj = client.findType(CFG.SISTEMA_RECOMPENSAS_GRAPHIC, null, null, null, RANGO_SISTEMA_RECOMPENSAS);
  if (!obj) {
    err(`No se encontró el Sistema de Recompensas a ${RANGO_SISTEMA_RECOMPENSAS} casillas del personaje. Acércate a él y reinicia la macro.`);
    exit();
  }
  return obj.serial;
}

// La bolsa de herramientas puede contener una mezcla de mazo, mazo de plata,
// La bolsa de herramientas puede contener una mezcla de cualquiera de las 5
// herramientas válidas (ver BLOQUE 2) — con que haya al menos una, es válida.
function contarHerramientasEnBolsa(serial: number): number {
  let total = 0;
  for (const h of HERRAMIENTAS) total += contarUnidades(serial, h.graphic, h.hue);
  return total;
}

function pedirBolsaDeHerramientas(paso: string): number {
  while (true) {
    cfg(`${paso} — Haz clic en la bolsa con herramientas (mazo, mazo mágico, martillo o martillo de herrero)...`);
    const t = target.query(false);
    if (!t || !t.serial) { err("Selección cancelada."); exit(); }

    abrirSiNecesario(t.serial);

    if (contarHerramientasEnBolsa(t.serial) > 0) return t.serial;

    err("Ahí no hay ninguna herramienta válida (mazo/mazo mágico/martillo/martillo de herrero). Selecciona la bolsa correcta...");
  }
}

// En modo macreo solo hacen falta 2 pasos (herramientas + lingotes); el Sistema
// de Recompensas se localiza solo. En modo armadura son 4 pasos.
const TOTAL_PASOS = MODO_MACREO ? 2 : 4;

// ── Paso 1: bolsa de herramientas (repuesto de mazos/martillos) ──
const serialBolsaHerramientas = pedirBolsaDeHerramientas(`1/${TOTAL_PASOS}`);

// ── Paso 2: bolsa de lingotes del material seleccionado ──
const serialBolsaLingotes = pedirBolsaConContenido(
  `2/${TOTAL_PASOS}`, ingotInfo.graphic, ingotInfo.hue, `lingotes de ${materialDef.nombre}`
);

let serialBolsaAlmacenadores = 0;
let serialBolsaDestinoArmadura = 0;
let serialSistemaRecompensas = 0;

if (!MODO_MACREO) {
  // ── Paso 3/4: bolsa de almacenadores de armaduras vacíos ──
  serialBolsaAlmacenadores = pedirBolsaConContenido(
    `3/${TOTAL_PASOS}`, CFG.ALMACENADOR_GRAPHIC, CFG.ALMACENADOR_HUE, "almacenadores de armaduras"
  );

  // ── Paso 4/4: bolsa DESTINO donde se guardarán los sets de armadura completos ──
  serialBolsaDestinoArmadura = pedirBolsaAbierta(
    `4/${TOTAL_PASOS}`, "la bolsa DESTINO (donde se guardarán los sets de armadura completos)"
  );
} else {
  // Sistema de Recompensas: se localiza automáticamente, sin pedir click.
  serialSistemaRecompensas = localizarSistemaRecompensas();
  cfg("Sistema de Recompensas localizado automáticamente.");
}


// ============================================================
// BLOQUE 8 — HERRAMIENTA: EQUIPAR Y REPONER
// ============================================================
//
// No hay una herramienta "elegida": cualquiera de las 5 válidas sirve. Estas
// funciones buscan la primera que encuentren, sin preferencia por ninguna.

function comoHerramienta(it: Item | undefined | null): Herramienta | null {
  if (!it) return null;
  for (const h of HERRAMIENTAS) {
    if (it.graphic === h.graphic && it.hue === h.hue) return h;
  }
  return null;
}

function herramientaEquipadaActual(): Herramienta | null {
  return comoHerramienta(player.equippedItems.oneHanded) || comoHerramienta(player.equippedItems.twoHanded);
}

// Busca cualquiera de las 5 herramientas válidas dentro de un contenedor.
function buscarHerramientaEn(serial: number): { item: Item; def: Herramienta } | null {
  for (const h of HERRAMIENTAS) {
    const it = client.findType(h.graphic, h.hue, { serial }, null, 0);
    if (it) return { item: it as Item, def: h };
  }
  return null;
}

function contarHerramientasEnMochila(): number {
  return contarHerramientasEnBolsa(player.backpack!.serial);
}

function reponerHerramientas(): boolean {
  const enMochila = contarHerramientasEnMochila();
  if (enMochila >= CFG.HERRAMIENTAS_DE_REPUESTO) return true;

  const encontrada = buscarHerramientaEn(serialBolsaHerramientas);
  if (!encontrada) return enMochila > 0;

  const caben = Math.floor(pesoLibre() / encontrada.def.peso);
  if (caben <= 0) return enMochila > 0;

  moverUnidades(serialBolsaHerramientas, player.backpack!.serial, encontrada.def.graphic, 1, encontrada.def.hue);
  return true;
}

function asegurarHerramientaEquipada(): boolean {
  if (!herramientaEquipadaActual()) {
    let spare = buscarHerramientaEn(player.backpack!.serial);
    if (!spare) {
      if (!reponerHerramientas()) { err("Sin herramientas (mazo/mazo mágico/martillo/martillo de herrero) disponibles. Macro detenida."); return false; }
      spare = buscarHerramientaEn(player.backpack!.serial);
      if (!spare) { err("Sin herramientas disponibles tras reponer. Macro detenida."); return false; }
    }
    player.equip(spare.item);
    sleep(CFG.SLEEP_MOVE);
  }
  // Mantener siempre una de repuesto en la mochila para cuando la equipada se rompa
  reponerHerramientas();
  return true;
}

// Carga inicial: equipar herramienta antes de arrancar el bucle
if (!asegurarHerramientaEquipada()) exit();


// ============================================================
// BLOQUE 9 — REPOSICIÓN DE LINGOTES
// ============================================================

function reponerLingotes(cantidadNecesaria: number): boolean {
  const en = contarUnidades(player.backpack!.serial, ingotInfo.graphic, ingotInfo.hue);
  if (en >= cantidadNecesaria) return true;

  const disponible = contarUnidades(serialBolsaLingotes, ingotInfo.graphic, ingotInfo.hue);
  if (disponible === 0) return en >= cantidadNecesaria;

  const objetivo = Math.max(cantidadNecesaria, CFG.LINGOTES_BUFFER);
  const faltan = Math.max(0, objetivo - en);
  const caben = Math.max(0, Math.floor(pesoLibre() / CFG.LINGOTE_PESO));
  const aMover = Math.min(faltan, disponible, caben);
  if (aMover > 0) {
    moverUnidades(serialBolsaLingotes, player.backpack!.serial, ingotInfo.graphic, aMover, ingotInfo.hue);
    sleep(1500); // esperar a que el servidor confirme la llegada a la mochila
  }

  const enTras = contarUnidades(player.backpack!.serial, ingotInfo.graphic, ingotInfo.hue);
  log(`[DEBUG post-move] en mochila tras mover: ${enTras} | necesarios: ${cantidadNecesaria}`);
  return enTras >= cantidadNecesaria;
}


// ============================================================
// BLOQUE 10 — ALMACENADORES DE ARMADURAS
// ============================================================
//
// Usamos UN almacenador por set completo: se van arrastrando dentro todas las
// piezas fabricadas de ese set y, cuando se han intentado todas las piezas
// configuradas, el almacenador (completo o parcial si faltó algún material)
// se mueve a la bolsa destino y se saca uno nuevo para el siguiente set.

function obtenerAlmacenadorEnMochila(): Item | null {
  let alm = client.findType(CFG.ALMACENADOR_GRAPHIC, CFG.ALMACENADOR_HUE, player.backpack, null, 0);
  if (alm) return alm as Item;

  const disponible = client.findType(CFG.ALMACENADOR_GRAPHIC, CFG.ALMACENADOR_HUE, { serial: serialBolsaAlmacenadores }, null, 0);
  if (!disponible) { err("Sin almacenadores de armaduras disponibles en la bolsa. Macro detenida."); return null; }

  const caben = Math.floor(pesoLibre() / CFG.ALMACENADOR_PESO);
  if (caben <= 0) { err("Peso insuficiente para cargar un almacenador."); return null; }

  player.moveItem(disponible, player.backpack!, 0, 0, 0, 1);
  sleep(CFG.SLEEP_MOVE);
  return client.findType(CFG.ALMACENADOR_GRAPHIC, CFG.ALMACENADOR_HUE, player.backpack, null, 0) as Item | null;
}

function meterPiezaEnAlmacenador(pieza: Item, almacenador: Item): void {
  // "Arrastrar" la pieza hasta soltarla sobre el almacenador = moveItem al serial del almacenador.
  // No se abre el gump del almacenador en ningún momento.
  player.moveItem(pieza, almacenador);
  sleep(CFG.SLEEP_MOVE);
}

function moverAlmacenadorADestino(): boolean {
  const alm = client.findType(CFG.ALMACENADOR_GRAPHIC, CFG.ALMACENADOR_HUE, player.backpack, null, 0);
  if (!alm) return false;
  player.moveItem(alm, { serial: serialBolsaDestinoArmadura }, 0, 0, 0, 1);
  sleep(CFG.SLEEP_MOVE);
  return true;
}


// ============================================================
// BLOQUE 11 — SISTEMA DE RECOMPENSAS (conversión de dagas a tickets)
// ============================================================

function convertirDagaATickets(daga: Item): boolean {
  journal.clear();
  player.use({ serial: serialSistemaRecompensas });

  let gump = esperarGumpConSerial(CFG.GUMP_RECOMPENSAS, CFG.TIMEOUT_NAV_GUMP, "apertura del Sistema de Recompensas");
  if (!gump) { err("No se abrió el gump del Sistema de Recompensas (0x4CD)."); return false; }

  gump.reply(CFG.BTN_RECOMPENSA_1); // id 2

  gump = esperarGumpConSerial(CFG.GUMP_RECOMPENSAS_2, CFG.TIMEOUT_NAV_GUMP, "tras primer botón del Sistema de Recompensas");
  if (!gump) { err("El gump de recompensas (0x4CE) no apareció tras el primer botón."); return false; }

  gump.reply(CFG.BTN_RECOMPENSA_2); // id 6

  const cursorAbierto = target.wait(3000);
  if (!cursorAbierto) { err("No se abrió el cursor de objetivo para la daga."); return false; }

  target.entity(daga);
  sleep(CFG.SLEEP_MOVE);
  return true;
}


// ============================================================
// BLOQUE 12 — CRAFTEO
// ============================================================

type ResultadoCraft = 'exito' | 'sin_material' | 'sin_skill' | 'error';

// Una vez elegido el material en el gump, el servidor lo recuerda mientras
// el menú siga siendo el mismo objeto. Solo hay que navegar material + páginas
// en la PRIMERA pieza de cada set. Las siguientes abren el gump directamente
// en el menú de categorías — solo hay que elegir categoría y pieza.
// Si hay un error de timeout (gump cerrado inesperadamente), se resetea este
// flag para renavegar el material completo en el siguiente intento.
let materialYaConfigurado = false;

// Espera un gump con el serial EXACTO indicado. Ya no se usa heurística de
// "cambio de serial": ahora sabemos que el menú de Herrería usa dos gumps
// distintos y conocidos (GUMP_HERRERIA=0x463 y GUMP_MATERIAL=0x464), así
// que basta con esperar el que corresponda en cada paso.
function esperarGumpConSerial(serialEsperado: number, timeoutMs: number, contexto: string): Gump | null {
  const g = Gump.findOrWait(serialEsperado, timeoutMs);
  if (g && g.exists) return g;
  log(`[HERRERIA][DEBUG] ${contexto}: no llegó el gump 0x${serialEsperado.toString(16)}. Gump.lastSerial=0x${Gump.lastSerial.toString(16)}`);
  return null;
}

function craftearPieza(pieza: DefPieza): ResultadoCraft {
  if (!asegurarHerramientaEquipada()) return 'error';
  if (!reponerLingotes(pieza.lingotes)) return 'sin_material';

  const lingote = client.findType(ingotInfo.graphic, ingotInfo.hue, player.backpack, null, 0);
  if (!lingote) return 'sin_material';

  journal.clear();
  player.use(lingote);
  let gumpPrincipal = esperarGumpConSerial(CFG.GUMP_HERRERIA, CFG.TIMEOUT_NAV_GUMP, "apertura del menú principal");
  if (!gumpPrincipal) { err("No se abrió el menú de Herrería (0x463)."); return 'error'; }

  if (!materialYaConfigurado) {
    // Paso 1: pulsar BTN_SELECCIONAR_MATERIAL (501) — el menú cambia al gump de material (0x464)
    gumpPrincipal.reply(CFG.BTN_SELECCIONAR_MATERIAL);
    let gumpMaterial = esperarGumpConSerial(CFG.GUMP_MATERIAL, CFG.TIMEOUT_NAV_GUMP, "entrar a selección de material");
    if (!gumpMaterial) { err("El menú desapareció al entrar a selección de material."); return 'error'; }

    // Paso 2: paginar dentro del gump de material (sigue siendo 0x464)
    for (let i = 1; i < materialDef.pagina; i++) {
      gumpMaterial.reply(CFG.BTN_SIGUIENTE);
      gumpMaterial = esperarGumpConSerial(CFG.GUMP_MATERIAL, CFG.TIMEOUT_NAV_GUMP, "paginar materiales");
      if (!gumpMaterial) { err("El menú desapareció al paginar materiales."); return 'error'; }
    }

    // Paso 3: elegir el material — el menú vuelve al gump principal (0x463)
    gumpMaterial.reply(materialDef.id);
    gumpPrincipal = esperarGumpConSerial(CFG.GUMP_HERRERIA, CFG.TIMEOUT_NAV_GUMP, "tras elegir el material");
    if (!gumpPrincipal) { err("El menú desapareció al elegir el material."); return 'error'; }

    materialYaConfigurado = true;
  }

  // Paso 4: elegir categoría (Coraza de Placas / Escudos / Esgrima) — sigue en 0x463
  gumpPrincipal.reply(pieza.categoriaId);
  gumpPrincipal = esperarGumpConSerial(CFG.GUMP_HERRERIA, CFG.TIMEOUT_NAV_GUMP, "tras elegir la categoría");
  if (!gumpPrincipal) { err("El menú desapareció al elegir la categoría."); return 'error'; }

  // Paso 5: elegir la pieza concreta y fabricar
  journal.clear();
  checkWorldSave();
  gumpPrincipal.reply(pieza.piezaId);

  const resp = journal.waitForTextAny(TODOS_MSGS_CRAFT, undefined, CFG.TIMEOUT_CRAFT);
  if (!resp) {
    // null (timeout) o undefined (ningún texto coincidió) — resetear y reintentar
    materialYaConfigurado = false;
    return 'error';
  }
  const respLower = resp.toLowerCase();
  if (JOURNAL_FABRICACION.SIN_MATERIAL.some(m => respLower.includes(m.toLowerCase()))) return 'sin_material';
  if (JOURNAL_FABRICACION.SIN_SKILL.some(m => respLower.includes(m.toLowerCase()))) return 'sin_skill';
  if (JOURNAL_FABRICACION.ERROR_CRAFT.some(m => respLower.includes(m.toLowerCase()))) return 'error';
  return 'exito';
}


// ============================================================
// BLOQUE 13 — BUCLE PRINCIPAL
// ============================================================

let piezasFabricadas = 0;
let setsCompletados   = 0;
let dagasConvertidas  = 0;

if (MODO_MACREO) {

  while (true) {
    const sk = player.getSkill(Skills.Blacksmith);
    if (sk && sk.value / 10 >= 110.0) {
      cfg("Blacksmith 100.0 alcanzado. Macro detenida.");
      break;
    }

    if (!reponerHerramientas()) { err("Sin herramientas de repuesto. Macro detenida."); break; }

    const resultado = craftearPieza(DAGA);

    if (resultado === 'exito') {
      piezasFabricadas++;
      const daga = client.findType(DAGA.resultGraphic, ingotInfo.hue, player.backpack, null, 0);
      if (daga) {
        if (convertirDagaATickets(daga as Item)) {
          dagasConvertidas++;
        } else {
          err("No se pudo convertir la daga en tickets. Se deja en la mochila.");
        }
      }
    } else if (resultado === 'sin_material') {
      err("Sin lingotes de Hierro para seguir fabricando dagas. Macro detenida.");
      break;
    } else if (resultado === 'sin_skill') {
      err("Skill insuficiente incluso para dagas de Hierro. Macro detenida.");
      break;
    } else {
      sleep(1000);
    }
  }

} else {

  while (true) {
    if (!reponerHerramientas()) { err("Sin herramientas de repuesto. Macro detenida."); break; }

    const almacenador = obtenerAlmacenadorEnMochila();
    if (!almacenador) break;

    let huboFalloMaterial = false;
    materialYaConfigurado = false; // cada set empieza navegando material desde cero

    for (const pieza of PIEZAS_DEL_SET) {
      checkWorldSave();
      const resultado = craftearPieza(pieza);

      if (resultado === 'exito') {
        piezasFabricadas++;
        const item = client.findType(pieza.resultGraphic, materialDef.hue, player.backpack, null, 0);
        if (item) {
          meterPiezaEnAlmacenador(item as Item, almacenador);
        } else {
          err(`Se fabricó "${pieza.nombre}" pero no se encontró en la mochila para guardarla.`);
        }
      } else if (resultado === 'sin_skill') {
        cfg(`Skill insuficiente para "${pieza.nombre}" en ${materialDef.nombre}. Pieza omitida.`);
      } else if (resultado === 'sin_material') {
        err(`Sin lingotes de ${materialDef.nombre} para continuar el set. Macro detenida.`);
        huboFalloMaterial = true;
        break;
      } else {
        err(`Fallo al craftear "${pieza.nombre}". Se omite esta pieza en este set.`);
        sleep(1000);
      }
    }

    // El almacenador se mueve al destino tanto si el set quedó completo como
    // si quedó parcial por fallos de skill (no de material) en alguna pieza.
    if (moverAlmacenadorADestino()) {
      setsCompletados++;
    }

    if (huboFalloMaterial) break;
  }
}

if (MODO_MACREO) {
  cfg(`Finalizado. Dagas fabricadas: ${piezasFabricadas}. Convertidas en tickets: ${dagasConvertidas}.`);
} else {
  cfg(`Finalizado. Piezas fabricadas: ${piezasFabricadas}. Sets movidos a destino: ${setsCompletados}.`);
}
