// Peso total de reactivos por craft (sin frasco, se cuenta aparte)
const pesoReactivosPorCraft = def.recursos.reduce((sum, r) => sum + r.cantidad * r.peso, 0);
// El frasco es el primer recurso siempre
const frascoEntry = def.recursos[0];

// Vaciar pociones ya fabricadas en mochila
const pocionsEnMochila = contarUnidades(player.backpack!.serial, def.resultGraphic, def.resultHue);
if (pocionsEnMochila > 0) {
  moverUnidades(player.backpack!.serial, serialDestino, def.resultGraphic, pocionsEnMochila, def.resultHue);
}

// Asegurar morteros
const morterosMochila = contarUnidades(player.backpack!.serial, CFG.MORTERO_GRAPHIC);
if (morterosMochila < CFG.MORTEROS_EN_MOCHILA) {
  const faltan = CFG.MORTEROS_EN_MOCHILA - morterosMochila;
  const caben = Math.floor(pesoLibre() / CFG.MORTERO_PESO);
  const aMover = Math.min(faltan, contarUnidades(serialBolsaMorteros, CFG.MORTERO_GRAPHIC), caben);
  if (aMover > 0) moverUnidades(serialBolsaMorteros, player.backpack!.serial, CFG.MORTERO_GRAPHIC, aMover);
}
if (contarUnidades(player.backpack!.serial, CFG.MORTERO_GRAPHIC) === 0) {
  err("Sin morteros disponibles. Macro detenida."); exit();
}

// Calcular cuántos crafts caben por peso
// En cada craft: peso resultado (frasco lleno) reemplaza al frasco vacío — peso neto = 0
// Pero durante el craft conviven reactivos + resultado en mochila momentáneamente
// Usamos: caben = floor((pesoLibre - resultPeso) / pesoReactivosPorCraft)
const pesoLibreActual = pesoLibre();
const craftsCaben = Math.floor((pesoLibreActual - def.resultPeso) / pesoReactivosPorCraft);

if (craftsCaben <= 0) {
  err(`Peso libre insuficiente para cargar reactivos. Tienes ${pesoLibreActual.toFixed(1)} libres.`);
  exit();
}

// Cargar reactivos iniciales — frascos de su bolsa específica, resto de reactivos de la bolsa de reactivos
for (const recurso of def.recursos) {
  const esFrasco = recurso.graphic === G.FRASCO;
  const bolsaOrigen = esFrasco ? serialBolsaFrascos : serialBolsaReactivos;

  const enMochila = contarUnidades(player.backpack!.serial, recurso.graphic, recurso.hue);
  const objetivo = recurso.cantidad * craftsCaben;
  const aCargar = Math.max(0, objetivo - enMochila);
  if (aCargar > 0) {
    const enBolsa = contarUnidades(bolsaOrigen, recurso.graphic, recurso.hue);
    moverUnidades(bolsaOrigen, player.backpack!.serial, recurso.graphic, Math.min(aCargar, enBolsa), recurso.hue);
  }
}

// Nivel objetivo: cuántos frascos (o primer recurso) tenemos ahora en mochila
const nivelObjetivo = contarUnidades(player.backpack!.serial, frascoEntry.graphic, frascoEntry.hue);
if (nivelObjetivo < frascoEntry.cantidad) {
  err("Sin frascos vacíos suficientes. Macro detenida."); exit();
}


