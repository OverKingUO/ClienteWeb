function reponerMorteros(): boolean {
  const en = contarUnidades(player.backpack!.serial, CFG.MORTERO_GRAPHIC);
  if (en >= CFG.MORTEROS_EN_MOCHILA) return true;
  const disponibles = contarUnidades(serialBolsaMorteros, CFG.MORTERO_GRAPHIC);
  if (disponibles === 0) return en > 0;
  const faltan = CFG.MORTEROS_EN_MOCHILA - en;
  const caben = Math.floor(pesoLibre() / CFG.MORTERO_PESO);
  const aMover = Math.min(faltan, disponibles, caben);
  if (aMover > 0) moverUnidades(serialBolsaMorteros, player.backpack!.serial, CFG.MORTERO_GRAPHIC, aMover);
  return contarUnidades(player.backpack!.serial, CFG.MORTERO_GRAPHIC) > 0;
}

function reponerReactivos(): boolean {
  for (const recurso of def.recursos) {
    const esFrasco = recurso.graphic === G.FRASCO;
    const bolsaOrigen = esFrasco ? serialBolsaFrascos : serialBolsaReactivos;

    const en = contarUnidades(player.backpack!.serial, recurso.graphic, recurso.hue);
    if (en >= recurso.cantidad) continue;
    const disponible = contarUnidades(bolsaOrigen, recurso.graphic, recurso.hue);
    if (disponible === 0) return false;
    const objetivo = recurso.cantidad * craftsCaben;
    const faltan = Math.max(0, objetivo - en);
    const caben = Math.max(0, Math.floor((pesoLibre() - def.resultPeso) / recurso.peso));
    const aMover = Math.min(faltan, disponible, caben);
    if (aMover > 0) moverUnidades(bolsaOrigen, player.backpack!.serial, recurso.graphic, aMover, recurso.hue);
  }
  // Comprobar que hay al menos para un craft completo
  for (const recurso of def.recursos) {
    if (contarUnidades(player.backpack!.serial, recurso.graphic, recurso.hue) < recurso.cantidad) return false;
  }
  return true;
}

// ── Gestión de keg en mochila ────────────────────────────────
//
// Mecánica real del keg en UA:
//   1. Doble clic en el keg (player.use)
//   2. Aparece un cursor de objetivo (target)
//   3. Clic en la poción que está en la mochila
//   → La poción desaparece, el frasco vuelve vacío, el keg sube 1 carga
//
// El keg tiene .amount = cargas actuales. Al llegar a 1000 está lleno.
// Mantenemos 1 keg en la mochila. Cuando se llena lo devolvemos a la
// bolsa y sacamos uno nuevo vacío (amount = 0).

function cargasKeg(keg: Item): number {
  return keg.amount ?? 0;
}

// Lee las cargas de un keg consultando sus propiedades OPL.
// Los kegs a medio llenar muestran en OPL algo como "Cargas: 450/1000".
// Si no se puede leer OPL (keg vacío o sin propiedades), devuelve keg.amount
// como fallback (que es 0 en kegs vacíos y el valor real en kegs con cargas).
function cargasKegOPL(keg: Item): number {
  try {
    const opl = client.queryItemOPL(keg.serial, 3000);
    if (opl && opl.data) {
      // Buscar patrón "N/1000" o "Cargas: N" en los datos OPL
      const matchSlash = opl.data.match(/(\d+)\s*\/\s*1000/);
      if (matchSlash) return parseInt(matchSlash[1], 10);
      const matchLabel = opl.data.match(/[Cc]argas[:\s]+(\d+)/);
      if (matchLabel) return parseInt(matchLabel[1], 10);
    }
  } catch (_) { /* OPL no disponible — usar fallback */ }
  // Fallback: .amount refleja las cargas cuando el keg ya tiene alguna
  return keg.amount ?? 0;
}

// ── Identificación de keg por nombre OPL ────────────────────
//
// El problema de identificar kegs por hue es que pociones distintas
// comparten color (ej: Fuerza y Fuerza Mejorada son ambas 0x02B8).
//
// Solución: leer el nombre del keg via queryItemOPL y comprobar que
// contiene el nombre de la poción que estamos fabricando.
// Un keg de "Fuerza Mejorada" tendrá en su OPL algo como:
//   "Barril de pociones de Fuerza Mejorada" o "Fuerza Mejorada"
// Un keg vacío no tiene nombre de poción — es válido para cualquier uso.
//
// Si OPL no está disponible (keg sin nombre) → usar fallback por hue,
// aceptando solo kegs vacíos (hue 0) para no mezclar.

function nombreKegOPL(keg: Item): string {
  try {
    const opl = client.queryItemOPL(keg.serial, 2000);
    if (opl?.name) return opl.name.toLowerCase();
    if (opl?.data) return opl.data.toLowerCase();
  } catch (_) {}
  return "";
}

function kegEsCompatible(keg: Item): boolean {
  const cargas = cargasKegOPL(keg);
  if (cargas >= CFG.LIMITE_KEG) return false; // lleno, no sirve

  if (cargas === 0 || keg.hue === 0x0000) return true; // vacío, sirve para cualquiera

  // Keg con contenido — comprobar que es de ESTA poción por nombre OPL
  const nombre = nombreKegOPL(keg);
  if (!nombre) {
    // Sin nombre OPL — usar hue como último recurso, solo si coincide exactamente
    return keg.hue === def.resultHue;
  }
  // El nombre del keg debe contener el nombre de la poción (case-insensitive)
  return nombre.includes(def.nombre.toLowerCase());
}

function buscarKegCompatibleEn(contenedor: any): Item | null {
  let mejorKeg:    Item | null = null;
  let mejorCargas: number      = -1;
  let kegVacio:    Item | null = null;

  for (const g of KEG_GRAPHICS) {
    const candidatos = client.findAllItemsOfType(g, null, contenedor, null, 0) as Item[];
    for (const k of candidatos) {
      if (!kegEsCompatible(k)) continue;
      const cargas = cargasKegOPL(k);
      if (cargas === 0 || k.hue === 0x0000) {
        if (!kegVacio) kegVacio = k; // guardar primer vacío como respaldo
      } else if (cargas > mejorCargas) {
        mejorCargas = cargas;
        mejorKeg    = k; // preferir el que ya tenga cargas de esta poción
      }
    }
  }
  return mejorKeg ?? kegVacio;
}

function reponerKegEnMochila(): boolean {
  // Paso 1: comprobar si ya hay un keg compatible en mochila con espacio
  const kegEnMochila = buscarKegCompatibleEn(player.backpack);
  if (kegEnMochila) return true; // ya hay uno, sin mensaje

  // Puede haber un keg en mochila pero lleno — devolverlo a la bolsa de kegs llenos
  for (const g of KEG_GRAPHICS) {
    const llenos = client.findAllItemsOfType(g, null, player.backpack, null, 0) as Item[];
    for (const k of llenos) {
      const cargas = cargasKegOPL(k);
      if (cargas >= CFG.LIMITE_KEG) {
        player.moveItem(k, { serial: serialKegLlenos }, 0, 0, 0, 1);
        sleep(CFG.SLEEP_MOVE);
      }
    }
  }

  // Paso 2: buscar en la bolsa de kegs vacíos/semillenos
  const kegEnBolsa = buscarKegCompatibleEn({ serial: serialDestino });
  if (!kegEnBolsa) {
    err(`No hay kegs disponibles para "${def.nombre}" (ni a medias, ni vacíos).`);
    return false;
  }

  player.moveItem(kegEnBolsa, player.backpack!, 0, 0, 0, 1);
  sleep(CFG.SLEEP_MOVE);
  return true;
}

function meterEnKeg(): boolean {
  let keg = buscarKegCompatibleEn(player.backpack);
  if (!keg) {
    if (!reponerKegEnMochila()) return false;
    keg = buscarKegCompatibleEn(player.backpack);
    if (!keg) return false;
  }

  if (cargasKegOPL(keg) >= CFG.LIMITE_KEG) {
    if (!reponerKegEnMochila()) return false;
    keg = buscarKegCompatibleEn(player.backpack);
    if (!keg) return false;
  }

  const pocion = client.findType(def.resultGraphic, def.resultHue, player.backpack, null, 0);
  if (!pocion) { err("No se encontró la poción en la mochila."); return false; }

  journal.clear();
  player.use(keg);
  const cursorAbierto = target.wait(3000);
  if (!cursorAbierto) { err("El keg no abrió cursor de objetivo."); return false; }
  target.entity(pocion);

  // Detectar si el servidor indica que el barril está lleno
  const respKeg = journal.waitForTextAny(["El barril esta lleno", "barril lleno"], undefined, 2000);
  if (respKeg !== null) {
    // El servidor lo confirmó — sacar el keg lleno y reponer
    if (!reponerKegEnMochila()) return false;
  }

  sleep(CFG.SLEEP_MOVE);
  return true;
}


// ── Cargar keg inicial en mochila si USAR_KEG ──
if (USAR_KEG) {
  if (!reponerKegEnMochila()) {
    err("No se pudo cargar ningún keg en la mochila. Macro detenida.");
    exit();
  }
}

// ============================================================
// BLOQUE 9 — BUCLE DE FABRICACIÓN
// ============================================================

let fabricadas = 0;

while (true) {

  // ── Skill cap si modo macreo ──
  if (CFG.MODO_MACREO) {
    const sk = player.getSkill(Skills.Alchemy);
    if (sk && sk.value / 10 >= 100.0) {
      cfg("Alchemy 100.0 alcanzado. Macro detenida.");
      break;
    }
  }

  // ── Vaciar cualquier poción acumulada antes de seguir ──
  // Esto garantiza que nunca queden 2 pociones del mismo color en mochila.
  // Se ejecuta al inicio de cada iteración, no solo tras éxito, así cubre
  // también pociones que pudieran haber quedado de iteraciones anteriores.
  if (USAR_KEG) {
    let pocionSuelta = client.findType(def.resultGraphic, def.resultHue, player.backpack, null, 0);
    while (pocionSuelta) {
      if (!meterEnKeg()) break;
      pocionSuelta = client.findType(def.resultGraphic, def.resultHue, player.backpack, null, 0);
    }
  }

  // ── Comprobar keg disponible ──
  if (USAR_KEG) {
    if (!reponerKegEnMochila()) break;
  }

  // ── Morteros ──
  if (!reponerMorteros()) break;

  // ── Reactivos ──
  if (!reponerReactivos()) break;

  // ── Abrir menú, navegar a la poción y fabricar ──
  const mortero = client.findType(CFG.MORTERO_GRAPHIC, null, player.backpack, null, 0);
  if (!mortero) { err("Mortero desapareció de la mochila."); break; }

  player.use(mortero);
  const gumpA = Gump.findOrWait(CFG.GUMP_ALQUIMIA, 3000);
  if (!gumpA || !gumpA.exists) {
    err("No se abrió el menú de alquimia. Reintentando...");
    sleep(1000);
    continue;
  }

  gumpA.reply(def.categoriaId);
  sleep(CFG.SLEEP_NAV);

  const gumpB = Gump.findOrWait(CFG.GUMP_ALQUIMIA, 2000);
  if (!gumpB || !gumpB.exists) {
    err("El menú desapareció al seleccionar categoría. Reintentando...");
    sleep(1000);
    continue;
  }

  if (def.paginaSiguiente) {
    gumpB.reply(CFG.BTN_SIGUIENTE);
    sleep(CFG.SLEEP_NAV);
    const gumpC = Gump.findOrWait(CFG.GUMP_ALQUIMIA, 2000);
    if (!gumpC || !gumpC.exists) {
      err("El menú desapareció al paginar. Reintentando...");
      sleep(1000);
      continue;
    }
    gumpC.reply(def.pocionId);
  } else {
    gumpB.reply(def.pocionId);
  }
  sleep(CFG.SLEEP_NAV);

  const gump = Gump.findOrWait(CFG.GUMP_ALQUIMIA, 2000);
  if (!gump || !gump.exists) {
    err("El menú desapareció al seleccionar poción. Reintentando...");
    sleep(1000);
    continue;
  }

  // Limpiar journal justo antes de fabricar y comprobar world save
  journal.clear();
  checkWorldSave();
  gump.reply(CFG.BTN_FABRICAR_ULTIMO);

  const resp = journal.waitForTextAny(TODOS_MSGS_CRAFT, undefined, CFG.TIMEOUT_CRAFT);

  if (resp === null) { sleep(1000); continue; }
  if (JOURNAL_FABRICACION.SIN_MATERIAL.some(m => resp.includes(m))) break;
  if (JOURNAL_FABRICACION.ERROR_CRAFT.some(m => resp.includes(m))) { sleep(1000); continue; }

  // Éxito — meter la poción en el keg o moverla al destino inmediatamente
  fabricadas++;

  const fabricada = client.findType(def.resultGraphic, def.resultHue, player.backpack, null, 0);
  if (fabricada) {
    if (USAR_KEG) {
      if (!meterEnKeg()) break;
    } else {
      player.moveItem(fabricada, { serial: serialDestino }, 0, 0, 0, 1);
      sleep(CFG.SLEEP_MOVE);
    }
  }
}

cfg(`Finalizado. Pociones fabricadas: ${fabricadas}.`);
