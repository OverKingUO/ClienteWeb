// BLOQUE 5 — SELECCIÓN DE BOLSAS
// ============================================================
//
// Problema conocido del cliente: abrir un contenedor padre cierra
// automáticamente las bolsas hijas que ya estaban abiertas.
// Solución: registramos todos los seriales ya abiertos y, si el
// usuario selecciona uno de ellos, no lo volvemos a abrir.

// ── Gestión de contenedores abiertos ────────────────────────
//
// El cliente cierra los contenedores hijos cuando se abre el padre.
// Para evitarlo, nunca llamamos a player.use() sobre un contenedor
// que el cliente ya tenga en memoria (abierto).
//
// ¿Cómo detectar si un contenedor ya está abierto?
// Si client.findObject(serial) devuelve el objeto Y ese objeto tiene
// .contents con al menos un elemento, el cliente ya tiene su contenido
// en memoria → está abierto. Si .contents está vacío podría ser un
// contenedor vacío abierto o uno cerrado; en ese caso usamos
// findAllItemsOfType como segunda comprobación: si el servidor nos
// devuelve items es que el cliente ya lo tiene cargado.
// Si ambas pruebas fallan, el contenedor está cerrado y hay que abrirlo.
//
// Importante: registramos el serial en bolsasAbiertas en cuanto el
// jugador lo selecciona con target.query(), independientemente de si
// la macro lo abrió o no, así los contenedores que el jugador ya tenía
// abiertos antes de lanzar la macro nunca se reabren.

const bolsasAbiertas: Set<number> = new Set();

// Considera abierto SOLO lo que la macro haya abierto explícitamente en esta sesión.
// No se fía de findObject — el cliente puede tener el objeto en memoria sin tener
// su contenido cargado, lo que causa que la primera caja nunca se abra.
function estaAbierto(serial: number): boolean {
  return bolsasAbiertas.has(serial);
}

function abrirSiNecesario(serial: number): void {
  if (estaAbierto(serial)) return; // ya en memoria — no reabrir, evita cerrar hijos
  player.use(serial);
  sleep(1200);
  bolsasAbiertas.add(serial);
}

function pedirBolsaConContenido(paso: string, graphic: number, hue: number | null, nombreItem: string): number {
  while (true) {
    cfg(`${paso} — Haz clic en la bolsa con ${nombreItem}...`);
    const t = target.query(false);
    if (!t || !t.serial) { err("Selección cancelada."); exit(); }

    // Primera vez siempre abrimos para cargar el contenido.
    // Si ya estaba abierto (registrado) no lo reabrimos.
    abrirSiNecesario(t.serial);

    if (contarUnidades(t.serial, graphic, hue) > 0) return t.serial;

    err(`Ahí no hay ${nombreItem}. Selecciona la bolsa correcta...`);
  }
}

function pedirBolsaAbierta(paso: string): number {
  cfg(`${paso} — Haz clic en el contenedor...`);
  const t = target.query(false);
  if (!t || !t.serial) { err("Selección cancelada."); exit(); }
  abrirSiNecesario(t.serial);
  return t.serial;
}

// ── Paso 1/4: bolsa de morteros ──
