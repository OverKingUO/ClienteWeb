function err(msg: string): void { client.sysMsg(`[ALQUIMIA] ⚠ ${msg}`, 0x26); }

function contarUnidades(serial: number, graphic: number, hue: number | null = null): number {
  const items = client.findAllItemsOfType(graphic, hue, { serial }, null, 0);
  let total = 0;
  for (const it of items) total += it.amount;
  return total;
}

function moverUnidades(origen: number, destino: number, graphic: number, cantidad: number, hue: number | null = null): number {
  let movidas = 0;
  while (movidas < cantidad) {
    const item = client.findType(graphic, hue, { serial: origen }, null, 0);
    if (!item) break;
    const aMover = Math.min(item.amount, cantidad - movidas);
    player.moveItem(item, { serial: destino }, 0, 0, 0, aMover);
    sleep(CFG.SLEEP_MOVE);
    movidas += aMover;
  }
  return movidas;
}

function pesoLibre(): number {
  return Math.max(0, player.weightMax - CFG.MARGEN_PESO_LIBRE - player.weight);
}

function checkWorldSave(): void {
  // Usar containsText solo si el mensaje está presente en el journal
  // en este momento. Para evitar falsos positivos por mensajes antiguos
  // acumulados, comprobamos solo si alguno de los textos de save está
  // en el journal Y limpiamos inmediatamente tras detectarlo.
  //
  // Si el bucle principal ya hizo journal.clear() antes de fabricar,
  // aquí solo pueden aparecer mensajes llegados DESPUÉS de ese clear.

  const hayAviso  = journal.containsText(WS_AVISO);
  const hayInicio = journal.containsText(WS_INICIO);

  if (!hayAviso && !hayInicio) return; // nada que hacer

  journal.clear(); // consumir el mensaje para no volver a detectarlo

  if (hayAviso) {
    client.sysMsg("[ALQUIMIA] Save en 1 min. Pausando...", 0x26);
    // Esperar a que empiece el save (máx 90s) y luego a que termine (máx 3min)
    journal.waitForText(WS_INICIO, undefined, 90000);
    journal.clear();
    journal.waitForText(WS_FIN, undefined, 180000);
    journal.clear();
  } else {
    // Ya estaba en curso cuando se llamó
    client.sysMsg("[ALQUIMIA] Save en curso. Esperando fin...", 0x26);
    journal.waitForText(WS_FIN, undefined, 180000);
    journal.clear();
  }

  client.sysMsg("[ALQUIMIA] Save terminado. Continuando.", 0x44);
  sleep(3000);
}


