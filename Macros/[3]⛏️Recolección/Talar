setup();

sysInfo("=== COMPROBACIONES INICIALES ===");
asegurarAlwaysRun();
asegurarPuntoInicio();
asegurarMontura();

sysInfo("Preparando personaje...");
asegurarHacha();
reponerReactivos();
comer();

sysInfo("Iniciando ciclo de tala...");

// Lista de árboles del bosque actual.
// Se escanea UNA SOLA VEZ por bosque y se reutiliza en visitas
// sucesivas al mismo bosque (por peso lleno).
let arbolesActuales: Arbol[] = [];
let bosqueEscaneado = false;

while (true) {
  checkWorldSave();
  asegurarMontura();
  recallBosque();
  asegurarHacha();

  // Escanear solo la primera vez que visitamos este bosque
  if (!bosqueEscaneado) {
    arbolesActuales = escanearArboles();
    bosqueEscaneado = true;
  }

  const bosqueTerminado = talarBosque(arbolesActuales, runaBosqueActual);

  recallCasa();
  descargarMochila();
  reponerReactivos();
  comer();
  asegurarHacha();

  if (bosqueTerminado) {
    sysInfo(`Bosque ${runaBosqueActual} agotado. Pasando al siguiente.`);
    bosqueEscaneado = false;
    arbolesActuales = [];
    siguienteBosque();
  } else {
    sysInfo(`Volviendo al bosque ${runaBosqueActual} a continuar...`);
    // bosqueEscaneado sigue true — no rescanea, continúa donde lo dejó
  }

  sleep(500);
}
